    if(scanStatus){scanStatus.textContent='📷 Starting camera…';scanStatus.style.display='block';}
    volStream=await navigator.mediaDevices.getUserMedia({
      video:{facingMode:{ideal:'environment'},width:{ideal:1280},height:{ideal:720}},audio:false
    });
    const video=document.getElementById('volVideo');
    video.srcObject=volStream;
    await video.play();
    volScanning=true;
    document.getElementById('volStartBtn').style.display='none';
    document.getElementById('volStopBtn').style.display='inline-block';
    document.getElementById('volResult').style.display='none';
    if(scanStatus){scanStatus.textContent='🟢 Camera ready — point at QR code';scanStatus.style.display='block';}

    // Always load jsQR — more reliable than BarcodeDetector for in-page canvas scanning
    if(!window.jsQR){
      if(scanStatus){scanStatus.textContent='⏳ Loading QR scanner…';}
      const s=document.createElement('script');
      s.src='https://cdnjs.cloudflare.com/ajax/libs/jsQR/1.4.0/jsQR.min.js';
      document.head.appendChild(s);
      await new Promise((res,rej)=>{s.onload=res;s.onerror=rej;});
    }
    if(scanStatus){scanStatus.textContent='🟢 Ready — point camera at QR code';}

    volScanInterval=setInterval(()=>{
      if(!volScanning)return;
      const vid=document.getElementById('volVideo');
      if(!vid||vid.readyState<vid.HAVE_ENOUGH_DATA||vid.videoWidth===0)return;
      const canvas=document.getElementById('volCanvas');
      canvas.width=vid.videoWidth;
      canvas.height=vid.videoHeight;
      const ctx=canvas.getContext('2d');
      ctx.drawImage(vid,0,0);
      if(window.jsQR){
        const img=ctx.getImageData(0,0,canvas.width,canvas.height);
        // Try both inversion modes for better detection
        const code=jsQR(img.data,img.width,img.height,{inversionAttempts:'attemptBoth'});
        if(code&&code.data&&volScanning){
          processQR(code.data);
          return;
        }
      }
      // Fallback: BarcodeDetector (Chrome Android)
      if('BarcodeDetector' in window&&volScanning){
        createImageBitmap(canvas).then(bmp=>{
          return new BarcodeDetector({formats:['qr_code']}).detect(bmp);
        }).then(codes=>{
          if(codes.length>0&&volScanning){processQR(codes[0].rawValue);}
        }).catch(()=>{});
      }
    },250);
  }catch(e){
    const scanStatus=document.getElementById('volScanStatus');
    if(scanStatus){scanStatus.textContent='❌ Camera error: '+e.message;scanStatus.style.display='block';}
    alert('Camera error: '+e.message+'\nPlease allow camera access and try again.');
  }
}

function stopVolScan(){
  volScanning=false;
  if(volScanInterval){clearInterval(volScanInterval);volScanInterval=null;}
  if(volStream){volStream.getTracks().forEach(t=>t.stop());volStream=null;}
  const video=document.getElementById('volVideo');
  if(video){video.srcObject=null;}
  document.getElementById('volStartBtn').style.display='inline-block';
  document.getElementById('volStopBtn').style.display='none';
  const scanStatus=document.getElementById('volScanStatus');
  if(scanStatus){scanStatus.style.display='none';}
}

// Holds the pending scanned data until operator confirms
let _pendingQR=null;

function processQR(raw){
  try{
    let payload=raw;
    if(raw.includes('?verify=')){payload=raw.split('?verify=')[1].split('&')[0];}
    // Decode payload — try new encodeURIComponent-based encoding first, fall back to legacy
    let d;
    try{
      d=JSON.parse(decodeURIComponent(atob(payload)));
    }catch(_){
      // Legacy fallback: old btoa(unescape(encodeURIComponent(...))) format
      try{d=JSON.parse(decodeURIComponent(escape(atob(payload))));}
      catch(e2){throw new Error('Invalid QR payload');}
    }
    // Normalise short keys to full keys (new compact format)
    if(d.n&&!d.name){d={name:d.n,dob:d.d,competition:d.c,division:d.div,corps:d.co,parent:d.p,date:d.dt};}
    stopVolScan();
    // Store pending data — do NOT send to sheet yet
    _pendingQR=d;
    showVolResult(d);
    // Show confirm bar, hide confirmed bar
    const cb=document.getElementById('volConfirmBar');
    const cd=document.getElementById('volConfirmedBar');
    if(cb)cb.style.display='block';
    if(cd)cd.style.display='none';
  }catch(e){
    // Not valid QR — keep scanning
    console.warn('QR parse failed:',e);
  }
}

function confirmVolAttendance(){
  if(!_pendingQR)return;
  const d=_pendingQR;
  _pendingQR=null;

  const confirmBtn=document.getElementById('volConfirmBtn');
  if(confirmBtn){confirmBtn.disabled=true;confirmBtn.textContent='⏳ Sending…';}

  const now=new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
  const entry={name:d.name,comp:d.competition,division:d.division,corps:d.corps,time:now,operator:currentOperator};
  volLog.unshift(entry);
  updateVolLog();

  if(admAllRows.length>0&&d.name){
    const nameLc=(d.name||'').toLowerCase().trim();
    let found=false;
    admAllRows.forEach(r=>{
      if((r[1]||'').toLowerCase().trim()===nameLc){
        found=true;
      }
    });
  }

  // Send attendance to Apps Script via JSONP for reliable callback
  const cb='_attSave'+Date.now();
  const s=document.createElement('script');
  const params=new URLSearchParams({
    action:'attendance',
    name:d.name||'',
    competition:d.competition||'',
    division:d.division||'',
    corps:d.corps||'',
    arrivedAt:now,
    operator:currentOperator||'',
    callback:cb
  });
  const t=setTimeout(()=>{
    s.remove();delete window[cb];
    // Show success even on timeout (offline resilient)
    showVolConfirmed();
  },8000);
  window[cb]=function(res){
    clearTimeout(t);s.remove();delete window[cb];
    console.log('Attendance saved:',res);
    showVolConfirmed();
  };
  s.onerror=()=>{clearTimeout(t);s.remove();delete window[cb];showVolConfirmed();console.warn('Attendance save failed');};
  s.src=APPS_SCRIPT_URL+'?'+params.toString();
  document.body.appendChild(s);
}

function showVolConfirmed(){
  const cb=document.getElementById('volConfirmBar');
  const cd=document.getElementById('volConfirmedBar');
  if(cb)cb.style.display='none';
  if(cd)cd.style.display='block';
}

function showVolResult(d){
  document.getElementById('vol-name').textContent=d.name||'—';
  document.getElementById('vol-dob').textContent=d.dob||'—';
  document.getElementById('vol-comp').textContent=d.competition||'—';
  document.getElementById('vol-div').textContent=d.division||'—';
  document.getElementById('vol-corps').textContent=d.corps||'—';
  document.getElementById('vol-parent').textContent=d.parent||'—';
  document.getElementById('vol-date').textContent=d.date||'—';
  document.getElementById('volResult').style.display='block';
  document.getElementById('volResult').scrollIntoView({behavior:'smooth'});
}

function resetVolScan(){
  _pendingQR=null;
  document.getElementById('volResult').style.display='none';
  const cb=document.getElementById('volConfirmBar');
  const cd=document.getElementById('volConfirmedBar');
  if(cb)cb.style.display='none';
  if(cd)cd.style.display='none';
  startVolScan();
}

function updateVolLog(){
  const logEl=document.getElementById('vol-log');
  document.getElementById('vol-count').textContent=volLog.length;
  if(!volLog.length){logEl.innerHTML='<div style="color:#555;font-size:.78rem;text-align:center;padding:1rem">No scans yet</div>';return;}
  logEl.innerHTML=volLog.map((e,i)=>`
    <div style="display:flex;justify-content:space-between;align-items:center;padding:.4rem .5rem;border-bottom:1px solid #1a1a1a;${i===0?'background:#1a2e1a;border-radius:6px':''}">
      <span style="color:#ccc;font-size:.78rem;font-weight:600">${e.name}</span>
      <div style="text-align:right">
        <span style="color:#aaa;font-size:.7rem;display:block">${e.comp}</span>
        <span style="color:#4caf50;font-size:.65rem;display:block">👤 ${e.operator||'—'}</span>
        <span style="color:#555;font-size:.65rem">${e.time}</span>
      </div>
    </div>`).join('');
}
</script>

