      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'meta-llama/llama-4-scout-17b-16e-instruct',
        max_tokens:512,
        messages:[{role:'user',content:[
          {type:'image_url',image_url:{url:`data:${file.type};base64,${b64}`}},
          {type:'text',text:`You are a precise OCR system for government ID documents.
Examine this ID card image. Extract the following and return ONLY a JSON object (no markdown, no preamble, no explanation):
{
  "full_name": "complete full name exactly as printed on the ID — include all words (first, middle, last) — do not shorten or abbreviate, or null if not readable",
  "date_of_birth": "in DD/MM/YYYY format, or null if not found",
  "gender": "one of: Male, Female, Transgender, or null if not found",
  "id_type": "one of: Aadhaar Card, Voter ID, Passport, Driving Licence, PAN Card, Other",
  "id_number": "show only last 4 digits, mask rest with X, e.g. XXXX-XXXX-1234, or null"
}
If this is NOT an ID card, add "error": "Not an ID card" and set other fields to null.
IMPORTANT: date_of_birth must strictly follow DD/MM/YYYY with 2-digit day, 2-digit month, 4-digit year.
IMPORTANT: full_name must be the complete name as it appears — never use initials in place of full words.`}
        ]}]
      })
    });
    if(!res.ok){const err=await res.json().catch(()=>({}));throw new Error(err?.error?.message||'API error '+res.status);}
    const data=await res.json();
    const txt=data.choices[0].message.content;
    let parsed;
    try{parsed=extractJSON(txt);}
    catch(pe){throw new Error(pe.message);}
    if(parsed.error&&!parsed.full_name&&!parsed.date_of_birth)throw new Error(parsed.error);
    if(!parsed.full_name&&!parsed.date_of_birth&&!parsed.gender)throw new Error('No readable text found. Please upload a well-lit, clear photo of your ID.');

    D.name=formatNameInitialLast(parsed.full_name||'Not detected');
    D.fullName=parsed.full_name||'Not detected'; // raw full name for sheet
    D.dob=parsed.date_of_birth||'';
    D.gender=parsed.gender||'Not detected';
    D.idType=parsed.id_type||'Unknown';
