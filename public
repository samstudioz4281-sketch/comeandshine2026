function showConfirmSummary(){
  const parentName=document.getElementById('f-parent').value.trim();
  const phone=document.getElementById('f-ph').value.trim().replace(/\s+/g,'');
  const divSel=document.getElementById('divisionSelect').value;
  const corpsSel=document.getElementById('corpsSelect').value;

  // Get competition — handle radio, hidden input, or comp_choice radio
  let competition='';
  const radioChecked=document.querySelector('input[name="activity"]:checked')||document.querySelector('input[name="comp_choice"]:checked');
  if(radioChecked) competition=radioChecked.value;
  if(!competition){
    const fixed=document.getElementById('comp-fixed');
    if(fixed) competition=fixed.value;
  }

  if(!parentName){showErr('e3','Please enter Parent / Guardian name.');return;}
  if(!phone){showErr('e3','Please enter a phone number.');return;}
  if(!/^\d{10}$/.test(phone)){showErr('e3','Phone number must be exactly 10 digits.');return;}
  if(!divSel){showErr('e3','Please select a Division.');return;}
  if(Object.keys(CORPS_DATA).some(k=>divSel.startsWith(k))&&!corpsSel){showErr('e3','Please select a Corps.');return;}
  if(!competition){showErr('e3','Please select a competition.');return;}
  clearErr('e3');

  // Fill confirm modal fields
  const fname=D.fname||document.getElementById('f-fn').value||'—';
  const safeEl=(id,val)=>{const el=document.getElementById(id);if(el)el.textContent=val;};
  safeEl('cs-fullname',fname);
  safeEl('cs-name',fname);
  safeEl('cs-dob-sub',(D.dob||'—')+' · '+(D.gender||''));
  safeEl('cs-dob',D.dob||'—');
  safeEl('cs-gender',D.gender||'—');
  safeEl('cs-parent',parentName);
  safeEl('cs-phone',phone);
  safeEl('cs-div',divSel);
  safeEl('cs-corps',corpsSel||'—');
  safeEl('cs-comp',competition);

  // Show photo if uploaded
  const csPhotoWrap=document.getElementById('cs-photo-wrap');
  const csPhoto=document.getElementById('cs-photo');
  if(photoB64&&photoMime){
    csPhoto.src='data:'+photoMime+';base64,'+photoB64;
    csPhotoWrap.style.display='flex';
  } else {
    csPhotoWrap.style.display='none';
  }

  document.getElementById('confirmOverlay').style.display='block';
  document.getElementById('confirmModal').style.display='block';
  document.getElementById('confirmModal').scrollTop=0;
}
function closeConfirmSummary(){
  document.getElementById('confirmOverlay').style.display='none';
  document.getElementById('confirmModal').style.display='none';
}

async function saveAsJpg(){
  const btn=document.getElementById('saveJpgBtn');
  btn.disabled=true;
  btn.textContent='⏳ Generating…';
  try{
    const card=document.getElementById('reg-capture-card');
    const canvas=await html2canvas(card,{
      backgroundColor:'#ffffff',
      scale:2,
      useCORS:true,
      allowTaint:true,
      logging:false
    });
    const link=document.createElement('a');
    const regId='registration';
    const name=(document.getElementById('tk-name-row').textContent||'card').replace(/\s+/g,'_');
    link.download='ComeAndShine_'+name+'_'+regId+'.jpg';
    link.href=canvas.toDataURL('image/jpeg',0.95);
    link.click();
    btn.disabled=false;
    btn.textContent='📥 Save Registration Card as JPG';
  }catch(err){
    btn.disabled=false;
    btn.textContent='📥 Save Registration Card as JPG';
    alert('Could not generate image. Please try again.\n'+err.message);
  }
}

