<script>
/* ── Robust JSON extractor ── */
function extractJSON(raw){
  // 1. strip markdown fences
  let s=raw.replace(/```json\s*/gi,'').replace(/```\s*/g,'').trim();
  // 2. try direct parse
  try{return JSON.parse(s);}catch(_){}
  // 3. find first complete {...} block
  const m=s.match(/\{[\s\S]*\}/);
  if(m){try{return JSON.parse(m[0]);}catch(_){}}
  // 4. try to fix common issues: trailing commas, single quotes
  try{
    let fixed=s.replace(/,\s*([}\]])/g,'$1').replace(/'/g,'"');
    const m2=fixed.match(/\{[\s\S]*\}/);
    if(m2)return JSON.parse(m2[0]);
  }catch(_){}
  // 5. build object from key:value patterns as last resort
  try{
    const obj={};
    const pairs=s.matchAll(/"?([\w_]+)"?\s*:\s*"?([^",}\n]+)"?/g);
    for(const [,k,v] of pairs) obj[k.trim()]=v.trim().replace(/^"|"$/g,'');
    if(Object.keys(obj).length>0)return obj;
  }catch(_){}
  throw new Error('Could not parse AI response — please try a clearer image.');
}

/* ── Name formatter ── */
/* Name as-is from ID, CAPS, surname first, initials of rest at end */
/* e.g. "John Paul Thomas" → "THOMAS J P"                           */
/* e.g. "Mary Joseph"      → "JOSEPH M"                             */
/* e.g. "David"            → "DAVID"                                */
function formatNameInitialLast(raw){
  if(!raw||raw==='Not detected')return raw;
  // Clean and split
  const parts=raw.trim().split(/[\s,]+/).map(p=>p.replace(/\./g,'').toUpperCase()).filter(Boolean);
  const initials=parts.filter(p=>p.length===1);
  const full=parts.filter(p=>p.length>1);
  // Full names first, then initials at end
  return [...full,...initials].join(' ');
}


const REGISTRY=[];
function dupKey(name,dob,gender,parent,division,corps){
  return [name,dob,gender,parent,division,corps]
    .map(v=>(v||'').trim().toLowerCase().replace(/\s+/g,''))
    .join('|');
}
function findDup(name,dob,gender,parent,division,corps){
  const k=dupKey(name,dob,gender,parent,division,corps);
  return REGISTRY.find(r=>r.key===k)||null;
}

