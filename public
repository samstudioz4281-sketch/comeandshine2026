const APPS_SCRIPT_URL='https://script.google.com/macros/s/AKfycbxzB7nP4T3ZH9WrCHHaW-sK_mbBVVqrA7UXcfchRc1uPY6AnKxZGGieZ2l6rO8uJgYb/exec';

function getNextSerial(){
  return new Promise((resolve)=>{
    const cb='_serialCb'+Date.now();
    const s=document.createElement('script');
    const t=setTimeout(()=>{s.remove();delete window[cb];resolve(Math.floor(Date.now()/1000)%9000+1);},6000);
    window[cb]=function(res){
      clearTimeout(t);s.remove();delete window[cb];
      resolve(res.next||1);
    };
    s.onerror=()=>{clearTimeout(t);s.remove();delete window[cb];resolve(Math.floor(Date.now()/1000)%9000+1);};
    s.src=APPS_SCRIPT_URL+'?action=nextserial&callback='+cb;
    document.body.appendChild(s);
  });
}

let _submitting=false;

/* Upload a single image to Google Drive via Apps Script POST.
   Returns the public Drive URL string, or '' on failure. */
async function uploadImageToDrive(b64, mime, filename){
  if(!b64||!mime) return '';
  try{
    const res=await fetch(APPS_SCRIPT_URL,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({action:'uploadImage', filename, mime, data:b64})
    });
    if(!res.ok) return '';
    const json=await res.json();
    return json.url||'';
  }catch(e){
    console.warn('Image upload failed:',e);
    return '';
  }
}

async function submitToSheet(row){
  if(_submitting){console.warn('Duplicate submit blocked');return;}
  _submitting=true;
  try{
    const safeName=(row.name||'participant').replace(/[^a-zA-Z0-9_-]/g,'_');
    const ts=Date.now();

    // Upload ID card and face photo in parallel
    const [idUrl, photoUrl] = await Promise.all([
      uploadImageToDrive(idCardB64, idCardMime, `ID_${safeName}_${ts}`),
      uploadImageToDrive(photoB64,   photoMime,  `Photo_${safeName}_${ts}`)
    ]);

    const params=new URLSearchParams();
    params.append('action','save');
    const rowClean={...row};
    delete rowClean.action;
    rowClean.idCardUrl  = idUrl;
    rowClean.photoUrl   = photoUrl;
    Object.keys(rowClean).forEach(k=>params.append(k,String(rowClean[k]||'')));

    const cb='_submitCb'+Date.now();
    const s=document.createElement('script');
    const t=setTimeout(()=>{s.remove();delete window[cb];_submitting=false;console.warn('Sheet submit timeout');},12000);
    window[cb]=function(res){clearTimeout(t);s.remove();delete window[cb];_submitting=false;console.log('Sheet saved:',res.status);};
    s.onerror=()=>{clearTimeout(t);s.remove();delete window[cb];_submitting=false;console.warn('Sheet submit failed');};
    s.src=APPS_SCRIPT_URL+'?'+params.toString()+'&callback='+cb;
    document.body.appendChild(s);
    console.log('Sheet: submit fired with idCardUrl='+idUrl+' photoUrl='+photoUrl);
  }catch(e){
    _submitting=false;
    console.warn('Sheet submit error:',e);
  }
}

